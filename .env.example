# --- Database ---
POSTGRES_DB=fiberline
POSTGRES_USER=fiberline
POSTGRES_PASSWORD=change-me

# Used by backend in Docker — points to the `db` service
DATABASE_URL=postgresql+psycopg://fiberline:change-me@db:5432/fiberline

# Override for local-only backend (outside Docker):
# DATABASE_URL=postgresql+psycopg://fiberline:change-me@localhost:5432/fiberline

# --- AI Provider ---
AI_PROVIDER=azure
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- CORS ---
# Production: frontend is served from the same origin via nginx, so this is less critical.
# Local dev (frontend on :5173, backend on :8000):
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173

# --- Frontend (used only at build time or local dev) ---
VITE_API_URL=http://localhost:8000
